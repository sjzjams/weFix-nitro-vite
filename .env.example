# 数据库配置
DATABASE_URL="mysql://username:password@localhost:3306/repair_system"

# Redis配置
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# 微信小程序配置
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"
WECHAT_MCH_ID="your-merchant-id"
WECHAT_API_KEY="your-wechat-api-key"
WECHAT_CERT_PATH="./certs/apiclient_cert.pem"
WECHAT_KEY_PATH="./certs/apiclient_key.pem"

# API配置
API_BASE_URL="https://api.repair.example.com"
WS_BASE_URL="wss://ws.repair.example.com"

# 文件上传配置
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760" # 10MB
ALLOWED_FILE_TYPES="jpg,jpeg,png,gif,pdf,doc,docx"

# 日志配置
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"

# 安全配置
BCRYPT_ROUNDS="12"
RATE_LIMIT_WINDOW="15"
RATE_LIMIT_MAX="100"

# 地图服务配置（腾讯位置服务）
TENCENT_MAP_KEY="your-tencent-map-key"

# 短信服务配置
SMS_ACCESS_KEY="your-sms-access-key"
SMS_SECRET_KEY="your-sms-secret-key"
SMS_SIGN_NAME="your-sms-sign"
SMS_TEMPLATE_CODE="your-template-code"

# 邮件服务配置
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"

# 系统配置
SYSTEM_NAME="报修服务系统"
SYSTEM_VERSION="1.0.0"
ADMIN_EMAIL="admin@example.com"

# 开发环境配置
NODE_ENV="development"
PORT="3000"
HOST="0.0.0.0"